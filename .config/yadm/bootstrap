#!/bin/bash

set -euo pipefail

# -- Helpers ------------------------------------------------------------------

GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
NC='\033[0m'

info()    { echo -e "${CYAN}:: ${NC}$*"; }
success() { echo -e "${GREEN}:: ${NC}$*"; }
warn()    { echo -e "${YELLOW}:: ${NC}$*"; }
error()   { echo -e "${RED}:: ${NC}$*"; }

# Prompt user for confirmation. Returns 0 (yes) or 1 (skip).
confirm() {
    local prompt="${1:-Continue?}"
    echo -en "${YELLOW}:: ${prompt} [Y/n] ${NC}"
    read -r reply
    [[ -z "$reply" || "$reply" =~ ^[Yy]$ ]]
}

# Detect distro family
detect_distro() {
    if [[ -f /etc/os-release ]]; then
        . /etc/os-release
        case "$ID" in
            arch|endeavouros|manjaro|cachyos|garuda) echo "arch" ;;
            debian|ubuntu|pop|mint|elementary|zorin)  echo "debian" ;;
            *)
                case "${ID_LIKE:-}" in
                    *arch*)   echo "arch" ;;
                    *debian*) echo "debian" ;;
                    *)        echo "unknown" ;;
                esac
                ;;
        esac
    else
        echo "unknown"
    fi
}

pkg_install() {
    case "$DISTRO" in
        arch)   sudo pacman -S --needed --noconfirm "$@" ;;
        debian) sudo apt install -y "$@" ;;
    esac
}

pkg_update() {
    case "$DISTRO" in
        arch)   sudo pacman -Syu --noconfirm ;;
        debian) sudo apt update && sudo apt upgrade -y ;;
    esac
}

ensure_cargo() {
    if command -v cargo &>/dev/null; then
        return 0
    fi
    case "$DISTRO" in
        arch)
            pkg_install rust
            ;;
        debian)
            curl https://sh.rustup.rs -sSf | sh -s -- -y
            source "${HOME}/.cargo/env"
            ;;
    esac
}

# -- Main ---------------------------------------------------------------------

echo "=== Bootstrap yadm ==="

DISTRO=$(detect_distro)
if [[ "$DISTRO" == "unknown" ]]; then
    error "Unsupported distro. This script supports Arch-based and Debian-based systems."
    exit 1
fi

success "Detected: $DISTRO"

# -- System update ------------------------------------------------------------

if confirm "Update system packages?"; then
    pkg_update
    success "System updated"
fi

# -- Base packages ------------------------------------------------------------

if confirm "Install base packages (curl, git, htop, vim, zsh, tmux, etc.)?"; then
    case "$DISTRO" in
        arch)
            pkg_install base-devel fontconfig openssl pkgconf \
                curl git htop meld rsync tree unzip wget xclip \
                tmux vim zsh
            ;;
        debian)
            pkg_install build-essential fontconfig libfontconfig1-dev libssl-dev pkg-config \
                curl git htop meld rsync tree unzip wget xclip \
                tmux vim zsh
            ;;
    esac
    success "Base packages installed"
fi

# -- Shell: Prezto + Starship -------------------------------------------------

if confirm "Install prezto + starship (zsh framework & prompt)?"; then
    # Prezto
    if [[ ! -d "${ZDOTDIR:-$HOME}/.zprezto" ]]; then
        git clone --recursive https://github.com/sorin-ionescu/prezto.git "${ZDOTDIR:-$HOME}/.zprezto"
        success "Prezto installed"
    else
        warn "Prezto already installed, skipping"
    fi

    # Set zsh as default shell
    if [[ "$(basename "$SHELL")" != "zsh" ]]; then
        chsh -s "$(which zsh)"
        success "Default shell changed to zsh"
    fi

    # Starship
    case "$DISTRO" in
        arch)   pkg_install starship ;;
        debian) ensure_cargo && cargo install starship ;;
    esac
    success "Starship installed"
fi

# -- FiraCode Nerd Font -------------------------------------------------------
# Install font before terminal — needed for proper glyph rendering

if confirm "Install FiraCode Nerd Font?"; then
    case "$DISTRO" in
        arch)
            pkg_install ttf-firacode-nerd
            ;;
        debian)
            mkdir -p ~/.local/share/fonts/FiraCode
            curl -fsSL "https://github.com/ryanoasis/nerd-fonts/releases/download/v3.4.0/FiraCode.tar.xz" | tar -xJ -C ~/.local/share/fonts/FiraCode
            fc-cache -fv
            ;;
    esac
    success "FiraCode Nerd Font installed"
fi

# -- Terminal: Alacritty ------------------------------------------------------

if confirm "Install Alacritty terminal + theme?"; then
    # Alacritty
    case "$DISTRO" in
        arch)
            pkg_install alacritty
            ;;
        debian)
            ensure_cargo
            cargo install alacritty
            ;;
    esac

    # Alacritty theme
    if [[ ! -d ~/.config/alacritty/alacritty-theme ]]; then
        git clone --depth 1 https://github.com/alacritty/alacritty-theme.git \
            ~/.config/alacritty/alacritty-theme
        success "Alacritty theme installed"
    else
        warn "Alacritty theme already present, skipping"
    fi

    success "Alacritty installed"
fi

# -- CLI tools ----------------------------------------------------------------
# Arch: all available via pacman
# Debian: some need cargo or manual install

if confirm "Install CLI tools (bat, fd, fzf, lsd, ripgrep, zoxide, lazygit)?"; then
    case "$DISTRO" in
        arch)
            pkg_install bat fd fzf lsd ripgrep zoxide lazygit
            ;;
        debian)
            pkg_install bat fd-find fzf lsd ripgrep zoxide
            # lazygit
            LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | \grep -Po '"tag_name": *"v\K[^"]*')
            LAZYGIT_ARCH=$(uname -m | sed -e 's/aarch64/arm64/')
            curl -Lo lazygit.tar.gz "https://github.com/jesseduffield/lazygit/releases/download/v${LAZYGIT_VERSION}/lazygit_${LAZYGIT_VERSION}_Linux_${LAZYGIT_ARCH}.tar.gz"
            tar xf lazygit.tar.gz lazygit
            sudo install lazygit -D -t /usr/local/bin/
            ;;
    esac
    success "CLI tools installed"
fi

# -- Tmux plugins -------------------------------------------------------------

if confirm "Install tmux plugins (TPM)?"; then
    if [[ ! -d ~/.tmux/plugins/tpm ]]; then
        git clone --depth 1 https://github.com/tmux-plugins/tpm.git ~/.tmux/plugins/tpm
        success "TPM installed"
    else
        warn "TPM already installed"
    fi
    info "Installing tmux plugins..."
    ~/.tmux/plugins/tpm/bin/install_plugins
    success "Tmux plugins installed"
fi

# -- Rust & cargo packages ----------------------------------------------------

if confirm "Install cargo packages (http-server, cargo-update)?"; then
    ensure_cargo
    cargo install cargo-update http-server
    success "Cargo packages installed"
fi

# -- Python (pyenv) -----------------------------------------------------------

if confirm "Install pyenv (Python 3.12) ?"; then
    # pyenv build dependencies
    case "$DISTRO" in
        arch)   pkg_install zlib xz tk sqlite bzip2 readline libffi ;;
        debian) pkg_install zlib1g-dev libbz2-dev libreadline-dev \
                            libsqlite3-dev liblzma-dev libffi-dev tk-dev ;;
    esac

    # pyenv
    if [[ ! -d "${HOME}/.pyenv" ]]; then
        curl -fsSL https://pyenv.run | bash
        success "pyenv installed"
    else
        warn "pyenv already installed, skipping"
    fi

    export PYENV_ROOT="${HOME}/.pyenv"
    [[ -d "${PYENV_ROOT}/bin" ]] && export PATH="${PYENV_ROOT}/bin:${PATH}"
    eval "$(pyenv init -)"

    # Python
    PYTHON_VERSION="3.12.12"
    if ! pyenv versions --bare | grep -qF "$PYTHON_VERSION"; then
        info "Installing Python ${PYTHON_VERSION}..."
        pyenv install "$PYTHON_VERSION"
    else
        warn "Python ${PYTHON_VERSION} already installed"
    fi
    pyenv global "$PYTHON_VERSION"
    success "Python ${PYTHON_VERSION} set as global"
fi

if confirm "Install pip packages (tempit) ?"; then
    # Pip packages
    pip install --upgrade pip
    pip install --user tempit-manager
    success "Pip packages installed"
fi

# -- Networking & hardware tools ----------------------------------------------

if confirm "Install networking tools (arp-scan, minicom, wireguard, gparted)?"; then
    case "$DISTRO" in
        arch)   pkg_install arp-scan gparted libevent minicom wireguard-tools ;;
        debian) pkg_install arp-scan gparted libevent-dev minicom wireguard ;;
    esac
    success "Networking tools installed"
fi

# -- Done ---------------------------------------------------------------------

echo ""
success "Bootstrap complete!"
