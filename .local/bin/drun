#!/usr/bin/env python3
import yaml, subprocess, os, sys, argparse

DEFAULT_CONFIG = os.path.expanduser("~/.config/drun.yaml")

def build_cmd(name, c):
    cmd = ["docker", "run"]
    if c.get("rm"):          cmd += ["--rm"]
    if c.get("interactive"): cmd += ["-it"]
    if c.get("workdir"):     cmd += ["-w", c["workdir"]]
    if c.get("env-file"):    cmd += ["--env-file", os.path.expanduser(c["env-file"])]
    cmd += ["--name", name]
    for v in c.get("volumes", []):
        cmd += ["-v", f"{os.path.expanduser(v['host'])}:{v['container']}"]
    for p in c.get("ports", []):
        cmd += ["-p", f"{p['host']}:{p['container']}"]
    cmd.append(c["image"])
    return cmd


parser = argparse.ArgumentParser(description="Run docker containers from a YAML file")
parser.add_argument("--file", "-f", default=DEFAULT_CONFIG, help="YAML config file (default: %(default)s)")
parser.add_argument("name", nargs="?", help="container name to run")
parser.add_argument("--list", "-l", action="store_true", help="list available containers")
args = parser.parse_args()

with open(args.file) as f:
    config = yaml.safe_load(f)

containers = config.get("containers", {})

if args.list or not args.name:
    print("Available containers:")
    for name in containers:
        print(name)
    sys.exit(0)

if args.name not in containers:
    print(f"Error: container '{args.name}' not found", file=sys.stderr)
    sys.exit(1)

cmd = build_cmd(args.name, containers[args.name])
print("$", " ".join(cmd))
subprocess.run(cmd)
